# Local secrets for the eval scripts (scripts/eval-checks.ts, scripts/eval-batch.ts).
# Copy this file to .env.local and fill in the values:
#
#   cp .env.example .env.local
#
# .env.local is gitignored — never commit real keys. The app itself does NOT use
# this file (keys live in browser localStorage); it's only for the Node scripts.
# Real environment variables take precedence over anything set here.

# Anthropic key for note generation (required by both eval scripts).
ANTHROPIC_API_KEY=

# Prompts: provide ONE of the two below.
#   GITHUB_TOKEN — fetch prompts/golden examples from the private data repo.
GITHUB_TOKEN=
#   PROMPTS_DIR — use a local copy of data/prompts instead (faster iteration).
# PROMPTS_DIR=

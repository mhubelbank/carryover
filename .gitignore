# OS
.DS_Store
Thumbs.db

# Dependencies (matches app/node_modules too)
node_modules/
.npm/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
*.local

# Vite / TypeScript caches
.vite/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/

# Environment / secrets
# (Keys live in browser localStorage, not files — but never commit env files.)
.env
.env.*
!.env.example

# Editors
.idea/
*.swp
*.swo

# App data lives in a separate private repo (carryover-data), fetched at runtime
# via the GitHub API — never in this repo. Ignore any local data/ scratch dir.
/data/

# Eval script output (generated notes for manual review)
eval-output/

# The npm package lives in app/ — guard against a stray root manifest/lockfile
# (e.g. from running npm at the repo root, or Cloudflare auto-config).
/package.json
/package-lock.json
